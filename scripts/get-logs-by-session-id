#!/bin/sh
# Usage: get-logs-by-session-id <session-id>
# Shows all daemon and plugin log entries for a given session, sorted by timestamp.
# Handles both JSON daemon logs and key=value plugin log formats.
#
# Env overrides:
#   AGENTS_OFFICE_LOG_DIR    base log dir (default: ~/.agents-office/logs)
#   AGENTS_OFFICE_DAEMON_LOG path to daemon log file
#   AGENTS_OFFICE_PLUGIN_LOG path to plugin log file

SID="${1:?Usage: get-logs-by-session-id <session-id>}"

exec "$(dirname "$0")/analyze-logs" --sid "$SID" --verbose
