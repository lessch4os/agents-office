{
  "name": "agents-office-daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/main.ts",
    "test": "bun test",
    "test:e2e": "bun test src/web-health.e2e.ts",
    "build:daemon": "bun build --compile --target=bun ./src/main.ts --outfile=agents-office",
    "build:hook": "bun build --compile --target=bun ./src/hook-shim.ts --outfile=agents-office-hook",
    "build:plugin": "tsc src/opencode-plugin.ts --outDir dist --module esnext --target esnext --skipLibCheck --moduleResolution bundler",
    "build:daemon:linux-x64": "bun build --compile --target=bun-linux-x64 ./src/main.ts --outfile=agents-office-linux-x64",
    "build:daemon:linux-arm64": "bun build --compile --target=bun-linux-arm64 ./src/main.ts --outfile=agents-office-linux-arm64",
    "build:daemon:darwin-x64": "bun build --compile --target=bun-darwin-x64 ./src/main.ts --outfile=agents-office-darwin-x64",
    "build:daemon:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 ./src/main.ts --outfile=agents-office-darwin-arm64",
    "build:hook:linux-x64": "bun build --compile --target=bun-linux-x64 ./src/hook-shim.ts --outfile=agents-office-hook-linux-x64",
    "build:hook:linux-arm64": "bun build --compile --target=bun-linux-arm64 ./src/hook-shim.ts --outfile=agents-office-hook-linux-arm64",
    "build:hook:darwin-x64": "bun build --compile --target=bun-darwin-x64 ./src/hook-shim.ts --outfile=agents-office-hook-darwin-x64",
    "build:hook:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 ./src/hook-shim.ts --outfile=agents-office-hook-darwin-arm64",
    "build:release": "bun run build:daemon:linux-x64 && bun run build:daemon:linux-arm64 && bun run build:daemon:darwin-x64 && bun run build:daemon:darwin-arm64 && bun run build:hook:linux-x64 && bun run build:hook:linux-arm64 && bun run build:hook:darwin-x64 && bun run build:hook:darwin-arm64 && bun run build:plugin"
  },
  "devDependencies": {
    "@types/node": "^22",
    "bun-types": "^1.3.14",
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/schema": "^0.75.5",
    "@effect/sql": "^0.51.1",
    "@effect/sql-sqlite-bun": "^0.52.0",
    "@effect/typeclass": "^0.40.0",
    "@opencode-ai/sdk": "^1.15.11",
    "effect": "^3.21.2"
  }
}
