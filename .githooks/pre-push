#!/usr/bin/env bash
# Pre-push hook: runs the same checks as GitHub Actions ci.yml before
# letting the push reach the remote. Set up once per clone with:
#
#   git config core.hooksPath .githooks
#
# Bypass for emergencies with `--no-verify` or `SKIP_PREFLIGHT=1`.
set -euo pipefail
exec "$(git rev-parse --show-toplevel)/scripts/preflight.sh"
